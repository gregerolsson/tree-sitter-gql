{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "gql",
      "camelcase": "GQL",
      "title": "GQL",
      "scope": "source.gql",
      "file-types": [
        "gql"
      ],
      "injection-regex": "^gql$",
      "class-name": "TreeSitterGql"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "GQL grammar for tree-sitter",
    "authors": [
      {
        "name": "greger.olsson <greger.olsson@veriscan.se>",
        "email": "greger.olsson@veriscan.se",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-gql",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}